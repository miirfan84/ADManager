<!-- Plugins\UserManagement\Tab.xaml -->
<!-- Self-contained XAML for the User Management tab.                      -->
<!-- Root element is a Grid — PluginLoader wraps it in a TabItem.          -->
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A252F" Margin="6">

    <Grid.Resources>

        <!-- Button template -->
        <ControlTemplate x:Key="RoundBtn" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource RoundBtn}"/>
        </Style>
        <Style x:Key="BlueBtn"   BasedOn="{StaticResource BaseBtn}" TargetType="Button">
            <Setter Property="Background" Value="#2980B9"/>
        </Style>
        <Style x:Key="OrangeBtn" BasedOn="{StaticResource BaseBtn}" TargetType="Button">
            <Setter Property="Background" Value="#E67E22"/>
        </Style>
        <Style x:Key="YellowBtn" BasedOn="{StaticResource BaseBtn}" TargetType="Button">
            <Setter Property="Background" Value="#D4A017"/>
        </Style>
        <Style x:Key="GrayBtn"   BasedOn="{StaticResource BaseBtn}" TargetType="Button">
            <Setter Property="Background" Value="#7F8C8D"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="DarkTB" TargetType="TextBox">
            <Setter Property="Background"      Value="#243447"/>
            <Setter Property="Foreground"      Value="#ECF0F1"/>
            <Setter Property="BorderBrush"     Value="#4A6278"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="White"/>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="DarkGrid" TargetType="DataGrid">
            <Setter Property="Background"               Value="#1E2D3D"/>
            <Setter Property="Foreground"               Value="#ECF0F1"/>
            <Setter Property="BorderBrush"              Value="#34495E"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#243447"/>
            <Setter Property="AlternatingRowBackground" Value="#1E2D3D"/>
            <Setter Property="GridLinesVisibility"      Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2C3E50"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#2C3E50"/>
            <Setter Property="SelectionMode"            Value="Extended"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="FontSize"                 Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#2C3E50"/>
            <Setter Property="Foreground"      Value="#ECF0F1"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderBrush"     Value="#34495E"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="25"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2471A3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Sep" TargetType="Separator">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Margin"     Value="0,8"/>
        </Style>

        <Style x:Key="SectionHdr" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#5DADE2"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

    </Grid.Resources>

    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════ LEFT PANEL ═══════════════════ -->
    <Border Grid.Column="0" Background="#1E2D3D"
            BorderBrush="#34495E" BorderThickness="1" CornerRadius="4" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Search section -->
                <TextBlock Text="SEARCH USERS" Style="{StaticResource SectionHdr}"/>

                <TextBlock Foreground="#7F8C8D" FontSize="11" Margin="0,0,0,5"
                           Text="Paste SAM or UPN accounts — one per line:"/>

                <TextBox x:Name="UM_TxtInput"
                         Style="{StaticResource DarkTB}"
                         Height="145" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="12"
                         Margin="0,0,0,4"/>

                <TextBlock Foreground="#566573" FontSize="10" FontStyle="Italic"
                           Margin="0,0,0,10"
                           Text="Tip: contains @ → UPN lookup  |  no @ → SAM lookup"/>

                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="UM_BtnSearch" Grid.Row="0" Grid.ColumnSpan="3"
                            Content="🔍 Search for Accounts" Style="{StaticResource BlueBtn}"
                            Height="34" IsEnabled="False"/>

                    <Button x:Name="UM_BtnImport" Grid.Row="2" Grid.Column="0"
                            Content="📂 Import (CSV/Excel)" Style="{StaticResource GrayBtn}"
                            Height="32" ToolTip="Import names from a CSV or Excel 'Name' column"/>

                    <Button x:Name="UM_BtnClear"  Grid.Row="2" Grid.Column="2"
                            Content="🗑 Clear All"  Style="{StaticResource GrayBtn}"
                            Height="32"/>
                </Grid>

                <Separator Style="{StaticResource Sep}"/>

                <!-- Actions section -->
                <TextBlock Text="ACTIONS" Style="{StaticResource SectionHdr}"/>

                <TextBlock x:Name="UM_TxtHint"
                           Text="Select rows in the grid to enable actions"
                           Foreground="#566573" FontSize="11" FontStyle="Italic"
                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                <Button x:Name="UM_BtnResetPwd"
                        Content="🔑  Reset Password"
                        Style="{StaticResource OrangeBtn}"
                        Height="34" Margin="0,0,0,8" IsEnabled="False"
                        ToolTip="Reset password for all selected users"/>

                <Button x:Name="UM_BtnForceChange"
                        Content="⏰  Force Change at Next Logon"
                        Style="{StaticResource YellowBtn}"
                        Height="34" Margin="0,0,0,8" IsEnabled="False"
                        ToolTip="Set must-change-password flag without resetting password"/>

                <Button x:Name="UM_BtnClearNeverExp"
                        Content="🚫  Clear Never Expire"
                        Style="{StaticResource GrayBtn}"
                        Height="34" Margin="0,0,0,8" IsEnabled="False"
                        ToolTip="Clear 'Password never expires' for selected users"/>

                <Button x:Name="UM_BtnCopySAM"
                        Content="📋  Copy SAM Names"
                        Style="{StaticResource GrayBtn}"
                        Height="34" IsEnabled="False"
                        ToolTip="Copy selected users SAM names to clipboard"/>

            </StackPanel>
        </ScrollViewer>
    </Border>

    <!-- ═══════════════════════════════════ SPLITTER ═════════════════════ -->
    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                  Background="#2C3E50" Cursor="SizeWE"/>

    <!-- ═══════════════════════════════════ RIGHT PANEL ══════════════════ -->
    <Border Grid.Column="2" Background="#1E2D3D"
            BorderBrush="#34495E" BorderThickness="1" CornerRadius="4" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Grid toolbar -->
            <Border Grid.Row="0" Padding="4,2,4,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="RESULTS"
                               Style="{StaticResource SectionHdr}"
                               Margin="0,4,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="UM_TxtTotal" Grid.Column="1"
                               Foreground="#7F8C8D" FontSize="11"
                               VerticalAlignment="Center" Text=""/>
                </Grid>
            </Border>

            <!-- Results DataGrid -->
            <DataGrid x:Name="UM_Grid" Grid.Row="1" Style="{StaticResource DarkGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Op"              Binding="{Binding OpStatus}"    Width="35"/>
                    <DataGridTextColumn Header="SAM Account"     Binding="{Binding SAM}"         Width="150"/>
                    <DataGridTextColumn Header="Display Name"    Binding="{Binding DisplayName}" Width="180"/>
                    <DataGridTextColumn Header="UPN"             Binding="{Binding UPN}"         Width="200"/>
                    <DataGridTextColumn Header="Email"           Binding="{Binding Email}"       Width="175"/>
                    <DataGridTextColumn Header="Enabled"         Binding="{Binding Enabled}"     Width="65"/>
                    <DataGridTextColumn Header="Never Expire"    Binding="{Binding PwNeverExp}"  Width="90"/>
                    <DataGridTextColumn Header="Pwd Last Set"    Binding="{Binding PwdLastSet}"  Width="145"/>
                    <DataGridTextColumn Header="Must Change"     Binding="{Binding MustChange}"  Width="100"/>
                    <DataGridTextColumn Header="Last Logon"      Binding="{Binding LastLogon}"   Width="145"/>
                    <DataGridTextColumn Header="Department"      Binding="{Binding Department}"  Width="130"/>
                    <DataGridTextColumn Header="Title"           Binding="{Binding Title}"       Width="130"/>
                    <DataGridTextColumn Header="OU"              Binding="{Binding OU}"          Width="200"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Grid status footer -->
            <Border Grid.Row="2" Background="#243447" CornerRadius="3"
                    Padding="8,4" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UM_TxtStatus" Grid.Column="0"
                               Foreground="#7F8C8D" FontSize="11"
                               Text="Enter accounts above and click Search"/>
                    <TextBlock x:Name="UM_TxtSelected" Grid.Column="1"
                               Foreground="#2980B9" FontSize="11" FontWeight="SemiBold"
                               Text="0 selected"/>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Grid>
