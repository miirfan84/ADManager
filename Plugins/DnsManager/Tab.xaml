<!-- Plugins\DnsManager\Tab.xaml -->
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A252F" Margin="6">

    <Grid.Resources>
        <!-- Button template -->
        <ControlTemplate x:Key="RoundBtn" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger>
                <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.35"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource RoundBtn}"/>
        </Style>
        <Style x:Key="BlueBtn"   BasedOn="{StaticResource Btn}" TargetType="Button"><Setter Property="Background" Value="#2980B9"/></Style>
        <Style x:Key="GreenBtn"  BasedOn="{StaticResource Btn}" TargetType="Button"><Setter Property="Background" Value="#27AE60"/></Style>
        <Style x:Key="OrangeBtn" BasedOn="{StaticResource Btn}" TargetType="Button"><Setter Property="Background" Value="#E67E22"/></Style>
        <Style x:Key="GrayBtn"   BasedOn="{StaticResource Btn}" TargetType="Button"><Setter Property="Background" Value="#7F8C8D"/></Style>
        <Style x:Key="RedBtn"    BasedOn="{StaticResource Btn}" TargetType="Button"><Setter Property="Background" Value="#C0392B"/></Style>

        <!-- DataGrid -->
        <Style x:Key="DarkGrid" TargetType="DataGrid">
            <Setter Property="Background"               Value="#1E2D3D"/>
            <Setter Property="Foreground"               Value="#ECF0F1"/>
            <Setter Property="BorderBrush"              Value="#34495E"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#243447"/>
            <Setter Property="AlternatingRowBackground" Value="#1E2D3D"/>
            <Setter Property="GridLinesVisibility"      Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2C3E50"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#2C3E50"/>
            <Setter Property="SelectionMode"            Value="Extended"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="FontSize"                 Value="12"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#2C3E50"/>
            <Setter Property="Foreground"      Value="#ECF0F1"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderBrush"     Value="#34495E"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="26"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2471A3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Grid.Resources>

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>  <!-- ROW 0: toolbar                  -->
        <RowDefinition Height="Auto"/>  <!-- ROW 1: input box                -->
        <RowDefinition Height="Auto"/>  <!-- ROW 2: progress bar             -->
        <RowDefinition Height="*"/>     <!-- ROW 3: data grid                -->
        <RowDefinition Height="Auto"/>  <!-- ROW 4: status bar               -->
    </Grid.RowDefinitions>

    <!-- ═══════════ ROW 0 — Top toolbar ═════════════════════════════════════ -->
    <Border Grid.Row="0" Background="#1E2D3D"
            BorderBrush="#34495E" BorderThickness="0,0,0,1" Padding="10,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- 0: Zone dropdown -->
                <ColumnDefinition Width="6"/>     <!-- 1: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 2: Load Zones -->
                <ColumnDefinition Width="10"/>    <!-- 3: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 4: Fetch -->
                <ColumnDefinition Width="6"/>     <!-- 5: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 6: Apply -->
                <ColumnDefinition Width="6"/>     <!-- 7: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 8: Delete -->
                <ColumnDefinition Width="6"/>     <!-- 9: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 10: Export -->
                <ColumnDefinition Width="*"/>     <!-- 11: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 12: WhatIf badge -->
                <ColumnDefinition Width="15"/>    <!-- 13: Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 14: WinRM label -->
            </Grid.ColumnDefinitions>

            <!-- Zone selector -->
            <ComboBox x:Name="DNS_CboZone" Grid.Column="0"
                      Width="200" Height="28"
                      Background="#243447" Foreground="Black"
                      BorderBrush="#4A6278" BorderThickness="1"
                      IsEnabled="False"
                      ToolTip="Select a DNS zone">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="#243447"/>
                        <Setter Property="Foreground"  Value="#ECF0F1"/>
                        <Setter Property="Padding"     Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#243447"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#ECF0F1"/>
                </ComboBox.Resources>
            </ComboBox>

            <!-- Load Zones -->
            <Button x:Name="DNS_BtnLoadZones" Grid.Column="2"
                    Content="🔄 Load Zones" Height="28"
                    Style="{StaticResource BlueBtn}"
                    IsEnabled="False"
                    ToolTip="Load forward zones from the DC"/>

            <!-- Fetch Records -->
            <Button x:Name="DNS_BtnFetch" Grid.Column="4"
                    Content="🔍 Fetch Records" Height="28"
                    Style="{StaticResource OrangeBtn}"
                    IsEnabled="False"
                    ToolTip="Fetch existing DNS records for the hostnames in the input box"/>

            <!-- Apply -->
            <Button x:Name="DNS_BtnApply" Grid.Column="6"
                    Content="▶ Apply" Height="28"
                    Style="{StaticResource GreenBtn}"
                    IsEnabled="False"
                    ToolTip="Apply planned DNS changes"/>

            <!-- Delete Selected -->
            <Button x:Name="DNS_BtnDelete" Grid.Column="8"
                    Content="🗑 Delete Selected" Height="28"
                    Style="{StaticResource RedBtn}"
                    IsEnabled="False"
                    ToolTip="Delete selected DNS records from the DC"/>

            <!-- Export -->
            <Button x:Name="DNS_BtnExport" Grid.Column="10"
                    Content="📤 Export" Height="28"
                    Style="{StaticResource GrayBtn}"
                    IsEnabled="False"
                    ToolTip="Export current grid data to XLSX"/>

            <!-- WhatIf toggle badge -->
            <Border Grid.Column="12" CornerRadius="4" Padding="10,5"
                    x:Name="DNS_WhatIfBadge" Background="#27AE60"
                    Cursor="Hand" ToolTip="Toggle Preview (ON) vs Write (OFF) mode">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🛡 WhatIf: " Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DNS_WhatIfLabel" Foreground="White" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" Text="ON"/>
                    <ToggleButton x:Name="DNS_WhatIfToggle"
                                  Width="0" Height="0" Opacity="0"
                                  IsChecked="True"/>
                </StackPanel>
            </Border>

            <!-- WinRM notice -->
            <TextBlock x:Name="DNS_LblWinRM" Grid.Column="14"
                       Foreground="#7F8C8D" FontSize="11"
                       VerticalAlignment="Center"
                       Text="Requires WinRM port 5985 on DC"/>
        </Grid>
    </Border>

    <!-- ═══════════ ROW 1 — Input box ════════════════════════════════════════ -->
    <TextBox x:Name="DNS_TxtInput" Grid.Row="1"
             AcceptsReturn="True"
             Height="90"
             IsEnabled="False"
             Background="#141E27" Foreground="#ECF0F1"
             BorderBrush="#34495E" BorderThickness="0,0,0,1"
             Padding="10,8"
             FontSize="12"
             CaretBrush="White"
             VerticalScrollBarVisibility="Auto"
             Margin="0,0,0,0"
             ToolTip="Paste records — one per line: app 192.168.1.1  or  app target.domain.com"/>

    <!-- ═══════════ ROW 2 — Progress bar ═════════════════════════════════════ -->
    <Grid Grid.Row="2" Margin="10,6,10,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <ProgressBar x:Name="DNS_Progress" Grid.Column="0"
                     Height="6" Minimum="0" Maximum="100" Value="0"
                     Background="#2C3E50" Foreground="#2980B9"
                     BorderThickness="0" Visibility="Collapsed"/>
        <TextBlock x:Name="DNS_ProgressLabel" Grid.Column="1"
                   Foreground="#7F8C8D" FontSize="10"
                   VerticalAlignment="Center" Margin="8,0,0,0"
                   Visibility="Collapsed"/>
    </Grid>

    <!-- ═══════════ ROW 3 — Data Grid ════════════════════════════════════════ -->
    <DataGrid x:Name="DNS_Grid" Grid.Row="3"
              Style="{StaticResource DarkGrid}"
              Margin="0,4,0,0">
        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsWildcard}" Value="True">
                        <Setter Property="Background"  Value="#3D3D3D"/>
                        <Setter Property="Foreground"  Value="#888888"/>
                        <Setter Property="IsEnabled"   Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
            <DataGridTextColumn Header="Status"         Binding="{Binding StatusLabel}"   Width="110" MinWidth="90"/>
            <DataGridTextColumn Header="Name"           Binding="{Binding Name}"          Width="120" MinWidth="100"/>
            <DataGridTextColumn Header="Type"           Binding="{Binding Type}"          Width="60"  MinWidth="50"/>
            <DataGridTextColumn Header="Existing Value" Binding="{Binding ExistingValue}" Width="160" MinWidth="120"/>
            <DataGridTextColumn Header="New Value"      Binding="{Binding NewValue}"      Width="160" MinWidth="120"/>
            <DataGridTextColumn Header="TTL"            Binding="{Binding TTL}"           Width="70"  MinWidth="50"/>
            <DataGridTextColumn Header="Match"          Binding="{Binding Match}"         Width="80"  MinWidth="60"/>
            <DataGridTextColumn Header="Result"         Binding="{Binding ResultNote}"    Width="200" MinWidth="120"/>
        </DataGrid.Columns>
    </DataGrid>

    <!-- ═══════════ ROW 4 — Status bar ═══════════════════════════════════════ -->
    <Border Grid.Row="4" Background="#141E27"
            BorderBrush="#2C3E50" BorderThickness="0,1,0,0" Padding="10,7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>    <!-- 0: Status text -->
                <ColumnDefinition Width="Auto"/> <!-- 1: Selection count -->
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DNS_StatusBar" Grid.Column="0"
                       Foreground="#7F8C8D" FontSize="11"
                       VerticalAlignment="Center"
                       Text="Connect to a DC to begin"/>

            <TextBlock x:Name="DNS_SelCount" Grid.Column="1"
                       Foreground="#2980B9" FontSize="11" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Text="0 selected"/>
        </Grid>
    </Border>

</Grid>
