<!-- Plugins\SyncManager\Tab.xaml -->
<!-- Sync Manager tab — connect to sync.alec.com, list Egnyte tasks, run + watch live. -->
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A252F" Margin="6">

    <Grid.Resources>

        <!-- Button template -->
        <ControlTemplate x:Key="RoundBtn" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource RoundBtn}"/>
        </Style>
        <Style x:Key="GreenBtn"  BasedOn="{StaticResource Btn}" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>
        <Style x:Key="BlueBtn"   BasedOn="{StaticResource Btn}" TargetType="Button">
            <Setter Property="Background" Value="#2980B9"/>
        </Style>
        <Style x:Key="OrangeBtn" BasedOn="{StaticResource Btn}" TargetType="Button">
            <Setter Property="Background" Value="#E67E22"/>
        </Style>
        <Style x:Key="RedBtn"    BasedOn="{StaticResource Btn}" TargetType="Button">
            <Setter Property="Background" Value="#C0392B"/>
        </Style>
        <Style x:Key="GrayBtn"   BasedOn="{StaticResource Btn}" TargetType="Button">
            <Setter Property="Background" Value="#7F8C8D"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="DarkTB" TargetType="TextBox">
            <Setter Property="Background"      Value="#243447"/>
            <Setter Property="Foreground"      Value="#ECF0F1"/>
            <Setter Property="BorderBrush"     Value="#4A6278"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SecHdr" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#5DADE2"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

        <!-- Task card style -->
        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background"     Value="#243447"/>
            <Setter Property="BorderBrush"    Value="#34495E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="4"/>
            <Setter Property="Padding"        Value="12,10"/>
            <Setter Property="Margin"         Value="0,0,0,6"/>
            <Setter Property="Cursor"         Value="Hand"/>
        </Style>

    </Grid.Resources>

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>   <!-- connection bar  -->
        <RowDefinition Height="*"/>      <!-- main content    -->
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════════ CONNECTION BAR ════════════════════ -->
    <Border Grid.Row="0" Background="#1E2D3D"
            BorderBrush="#34495E" BorderThickness="0,0,0,1" Padding="12,10" Margin="0,0,0,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Server name (pre-filled, editable) -->
            <TextBlock Grid.Column="0" Text="Sync Server:"
                       Foreground="#95A5A6" FontSize="12"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="SM_TxtServer" Grid.Column="1"
                     Style="{StaticResource DarkTB}"
                     Text="sync.alec.com" Height="28"
                     VerticalAlignment="Center" Margin="0,0,12,0"
                     MaxWidth="200"
                     ToolTip="Hostname of the sync server (uses AD credentials from main connection)"/>

            <!-- Status dot + label -->
            <Ellipse x:Name="SM_ConnDot" Grid.Column="2"
                     Width="10" Height="10" Margin="0,0,7,0"
                     VerticalAlignment="Center">
                <Ellipse.Fill><SolidColorBrush Color="#E74C3C"/></Ellipse.Fill>
            </Ellipse>
            <TextBlock x:Name="SM_ConnLabel" Grid.Column="3"
                       Text="Not connected" Foreground="#7F8C8D"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>

            <!-- Connect / Disconnect -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="SM_BtnConnect"    Content="🔌 Connect to Sync"
                        Style="{StaticResource GreenBtn}" Height="28" Margin="0,0,6,0"/>
                <Button x:Name="SM_BtnDisconnect" Content="✖ Disconnect"
                        Style="{StaticResource RedBtn}"   Height="28" IsEnabled="False"/>
            </StackPanel>

            <!-- Inline status message -->
            <TextBlock x:Name="SM_ConnMsg" Grid.Column="5"
                       Foreground="#E74C3C" FontSize="11" FontStyle="Italic"
                       VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="NoWrap"/>
        </Grid>
    </Border>

    <!-- ═══════════════════════════════ MAIN CONTENT ═══════════════════════ -->
    <Grid Grid.Row="1" Margin="8,0,8,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="EGNYTE SYNC TASKS" Style="{StaticResource SecHdr}" Margin="4,0,0,8"/>

        <!-- Live Sync DataGrid -->
        <DataGrid x:Name="SM_TaskGrid" Grid.Row="1" 
                  AutoGenerateColumns="False" HeadersVisibility="Column" 
                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                  IsReadOnly="True" SelectionMode="Single"
                  Background="#1E2D3D" RowBackground="#1E2D3D" AlternatingRowBackground="#243447" 
                  Foreground="#ECF0F1" BorderBrush="#34495E" BorderThickness="1"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2C3E50"
                  RowHeight="32">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2C3E50"/>
                    <Setter Property="Foreground" Value="#BDC3C7"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Task Name" Binding="{Binding Name}" Width="260"/>
                <DataGridTextColumn Header="Status" Binding="{Binding State}" Width="160"/>
                <DataGridTextColumn Header="Last Run Time" Binding="{Binding LastRunTime}" Width="160"/>
                <DataGridTextColumn Header="Result" Binding="{Binding ResultText}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer / Actions -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="SM_BtnRun" Grid.Column="0"
                    Content="▶ Run Selected Task"
                    Style="{StaticResource OrangeBtn}"
                    Height="32" Width="160"
                    IsEnabled="False"/>

            <TextBlock x:Name="SM_StatusText" Grid.Column="2"
                       Foreground="#7F8C8D" FontSize="12"
                       VerticalAlignment="Center"
                       Text="Connect to sync.alec.com to load tasks"/>
        </Grid>
    </Grid>

</Grid>
